      }
      .flow-line {
        font-size: 0.875rem;
        color: var(--ink-soft);
        margin: var(--s-2) 0 0;
        max-width: 72ch;
        line-height: 1.55;
      }

      /* ============================================================
         STAGE: RESULT
         ============================================================ */
      .stage-result { display: flex; flex-direction: column; gap: var(--s-5); }

      .result-hero {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: var(--s-6);
        align-items: start;
        padding: var(--s-5);
        background: var(--paper-edge);
        border: 1px solid var(--ink);
        position: relative;
      }
      .result-hero::before, .result-hero::after {
        content: ''; position: absolute;
        width: 14px; height: 14px;
        background: var(--paper-edge);
        border: 1px solid var(--ink);
      }
      .result-hero::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
      .result-hero::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
      @media (max-width: 760px) { .result-hero { grid-template-columns: 1fr; } }

      .hero-art {
        aspect-ratio: 4 / 3;
        background: var(--paper);
        border: 1px solid var(--rule);
        display: flex; align-items: center; justify-content: center;
        position: relative;
        overflow: hidden;
        border-radius: 2px;
      }
      .hero-art img { width: 100%; height: 100%; object-fit: cover; }
      .hero-art-cap {
        position: absolute;
        bottom: 6px; left: 6px;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        background: oklch(97% 0.012 80 / 0.92);
        padding: 2px 6px;
        border: 1px solid var(--rule);
        color: var(--ink-soft);
        border-radius: 2px;
      }
      .hero-art-cap a { color: var(--slate-blue); text-decoration: none; }
      .hero-art-cap a:hover { text-decoration: underline; }
      .hero-art-fallback {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: var(--s-2);
        color: var(--ink-mute);
        text-align: center;
        padding: var(--s-4);
        width: 100%; height: 100%;
      }
      .hero-art-loading {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-style: italic;
        color: var(--ink-mute);
      }
      .hero-art-fallback .kicker {
        font-size: 0.6rem;
        letter-spacing: 0.16em;
      }
      .hero-art-name {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 2.5vw, 1.75rem);
        font-weight: 600;
        color: var(--ink);
        line-height: 1.1;
        letter-spacing: -0.01em;
      }

      .hero-text { display: flex; flex-direction: column; gap: var(--s-3); }
      .result-product {
        font-family: var(--font-display);
        font-size: clamp(2.25rem, 4.5vw, 3rem);
        font-weight: 600;
        margin: 4px 0 0;
        color: var(--ink);
        letter-spacing: -0.025em;
        line-height: 1.05;
      }
      .result-summary {
        font-family: var(--font-body);
        font-size: 1.125rem;
        font-style: italic;
        color: var(--ink-soft);
        margin: 0;
        max-width: 56ch;
        line-height: 1.5;
      }
      /* Stats as a single horizontal definition list — looks like a real spec sheet */
      .hero-stats {
        display: flex; gap: var(--s-6);
        flex-wrap: wrap;
        padding-top: var(--s-3);
        margin-top: var(--s-2);
        border-top: 1px solid var(--rule);
        margin: 0;
      }
      .hero-stat { display: flex; flex-direction: column; gap: 2px; margin: 0; }
      .hero-stat-num {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        line-height: 1;
      }
      .hero-stat-unit { font-size: 0.85rem; color: var(--ink-mute); font-weight: 500; margin-left: 1px; }
      .hero-stat-lbl {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--ink-mute);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 500;
      }

      /* ---- Frames strip ---- */
      .frames-card, .bom-card, .meta-card {
        background: var(--paper-edge);
        border: 1px solid var(--rule);
        border-radius: 2px;
      }
      .card-head {
        padding: var(--s-4);
        border-bottom: 1px solid var(--rule);
        background: var(--paper);
        display: flex; align-items: baseline; justify-content: space-between;
        gap: var(--s-3);
      }
      .card-head h3 {
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
        letter-spacing: -0.01em;
      }
      .card-sub {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--ink-mute);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .frames-strip {
        padding: var(--s-3);
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: var(--s-2);
      }
      @media (max-width: 900px) { .frames-strip { grid-template-columns: repeat(4, 1fr); } }
      @media (max-width: 540px) { .frames-strip { grid-template-columns: repeat(3, 1fr); } }
      .frame-tile {
        margin: 0;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: 2px;
        overflow: hidden;
        transition: border-color 150ms ease, box-shadow 200ms ease, transform 200ms ease;
        cursor: pointer;
        position: relative;
      }
      .frame-tile:hover { border-color: var(--ink-soft); }
      .frame-tile:hover .frame-tile-img img { transform: scale(1.06); }
      /* "Click to find parts" hint shown on hover */
      .frame-tile::after {
        content: 'find parts \2193';
        position: absolute;
        bottom: 24px; left: 50%;
        transform: translateX(-50%) translateY(4px);
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--paper);
        background: oklch(22% 0.025 50 / 0.85);
        padding: 2px 6px;
        border-radius: 2px;
        opacity: 0;
        transition: opacity 150ms ease, transform 150ms ease;
        pointer-events: none;
        z-index: 2;
        white-space: nowrap;
      }
      .frame-tile:hover::after {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      .frame-tile.is-empty {
        border-color: var(--rust);
        animation: shake 300ms ease;
      }
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-3px); }
        75% { transform: translateX(3px); }
      }
      .frame-tile.is-empty::after {
        content: 'no parts here';
        opacity: 1;
        background: oklch(58% 0.18 30 / 0.9);
        transform: translateX(-50%) translateY(0);
      }
      .frame-tile-img {
        aspect-ratio: 16 / 9;
        background: var(--ink);
        position: relative;
        display: flex; align-items: center; justify-content: center;
        color: oklch(97% 0.012 80 / 0.4);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        overflow: hidden;
      }
      .frame-tile-img img {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
        transition: transform 400ms ease;
      }
      .frame-tile-num {
        position: absolute;
        top: 4px; left: 4px;
        background: oklch(22% 0.025 50 / 0.78);
        color: var(--paper);
        font-family: var(--font-mono);
        font-size: 0.6rem;
        padding: 1px 4px;
        border-radius: 1px;
        letter-spacing: 0.08em;
        z-index: 1;
      }
      .frame-tile-cap {
        padding: 3px 6px;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--ink-soft);
        text-align: right;
        background: var(--paper);
        font-variant-numeric: tabular-nums;
        border-top: 1px solid var(--rule-soft);
      }
      .frame-tile-ts {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
      }
      .frame-tile.is-highlighted {
        border-color: var(--sienna);
        box-shadow: 0 0 0 2px var(--sienna-soft);
        transition: border-color 200ms ease, box-shadow 200ms ease;
      }

      /* ---- BOM (table layout) ---- */
      .bom-tree { padding: 0; display: flex; flex-direction: column; gap: var(--s-5); }
      .bom-group {
        border: 1px solid var(--rule);
        background: var(--paper);
        border-radius: 2px;
        overflow: hidden;
      }
      .bom-group-head {
        display: flex; align-items: baseline; justify-content: space-between;
        padding: var(--s-3) var(--s-4);
        border-bottom: 1px solid var(--rule);
        background: var(--paper-crease);
        gap: var(--s-3);
      }
      .bom-group-head h4 {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
        letter-spacing: -0.005em;
      }
      .bom-group-count {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--ink-mute);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        flex-shrink: 0;
      }

      /* ---- Part card: horizontal layout for scannability ----
         ┌──────────────────────────────────────────────────────────┐
         │ [IMG]  Part Name                       1×                │
         │        short note · material            bomwiki ↗        │
         │        ████████████░░ 95% conf     ● frame 03 4.2s      │
         └──────────────────────────────────────────────────────────┘
         Image · name · meta line · confidence bar · frame proof,
         all in one tight horizontal card. */
      .part-art.has-image {
        border-color: var(--ink-soft);
      }
      .part-card:hover .part-art.has-image {
        border-color: var(--sienna);
      }
      /* ---- BOM table (real <table> for scannability) ----
         A spec-sheet feel: each row is one part, columns align across
         sub-assemblies so the eye can compare quantities, materials,
         confidence, and bomwiki links in a single glance. */
:global(.bom-table-wrap) {
        overflow-x: auto;
      }
:global(.bom-table) {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        background: var(--paper);
        /* Fixed layout: column widths are honored, content wraps inside cells
           instead of pushing the table wider. Predictable across rows. */
        table-layout: fixed;
      }
:global(.bom-table thead th) {
        text-align: left;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-mute);
        font-weight: 600;
        padding: 10px 10px;
        background: var(--paper-crease);
        border-bottom: 1px solid var(--rule);
        white-space: nowrap;
        vertical-align: bottom;
      }
:global(.bom-table thead th.col-num) { text-align: right; width: 56px; }
:global(.bom-table thead th.col-material) { width: 18%; }
:global(.bom-table thead th.col-conf) { text-align: right; width: 130px; }
:global(.bom-table thead th.col-frame) { width: 130px; }
:global(.bom-table thead th.col-bomwiki) { text-align: right; width: 110px; }
      /* Part column takes whatever's left (auto, min-widthed) */
:global(.bom-table thead th.col-part) { width: auto; }

:global(.bom-table tbody td) {
        padding: 8px 10px;
        border-bottom: 1px solid var(--rule-soft);
        vertical-align: middle;
        /* Allow long words to break rather than overflow the cell */
        overflow-wrap: anywhere;
      }
:global(.bom-table tbody tr:last-child td) { border-bottom: 0; }
:global(.bom-table tbody tr:hover) { background: var(--paper-edge); }
:global(.bom-table tbody tr.is-highlighted) {
        background: var(--sienna-soft);
        box-shadow: inset 3px 0 0 var(--sienna);
        animation: row-pop 700ms cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes row-pop {
        0%   { background: oklch(58% 0.18 35 / 0.25); }
        100% { background: var(--sienna-soft); }
      }

      /* Column: Part (name + note + art) */
      :global(.bom-table td.col-part),
:global(.bom-table th.col-part) { min-width: 220px; }
:global(.bom-part-inner) {
        display: flex; align-items: flex-start; gap: 10px;
        min-width: 0;
      }
:global(.bom-art) {
        background: var(--paper-edge);
        position: relative;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden;
        width: 40px; height: 40px;
        border: 1px solid var(--rule);
        border-radius: 1px;
        flex-shrink: 0;
      }
:global(.bom-art img) { width: 100%; height: 100%; object-fit: cover; }
:global(.bom-art-fallback) {
        display: flex; align-items: center; justify-content: center;
        width: 100%; height: 100%;
        color: var(--ink-mute);
        background:
          repeating-linear-gradient(
            45deg,
            transparent,
            transparent 3px,
            oklch(91% 0.022 78 / 0.5) 3px,
            oklch(91% 0.022 78 / 0.5) 4px
          );
      }
:global(.bom-art-initials) {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--ink-soft);
        letter-spacing: 0.02em;
      }
:global(.bom-text) { min-width: 0; flex: 1; }
:global(.bom-name) {
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--ink);
        line-height: 1.25;
        letter-spacing: -0.005em;
        word-break: break-word;
        /* Keep name to a single line; truncate if too long. The full name
           is still readable on hover via the title attribute. */
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
      }
:global(.bom-note) {
        font-size: 0.72rem;
        color: var(--ink-soft);
        font-style: italic;
        line-height: 1.35;
        margin-top: 2px;
        /* Note wraps to 2 lines max — keeps row height predictable */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* Multilingual evidence line — the "proof of looking" strip.
         Rendered under the part name only when the Detector read a
         real nameplate / decal. Layout: [「三菱重工業」 JP → "Mitsubishi..." · confirmed manufacturer]
         The "「」" marks + serif foreign text give it a typewriter-card
         feel; everything is small + muted so it doesn't fight the part
         name above it. Font fallback covers CJK / Arabic / Devanagari
         via OS default fonts. */
  :global(.bom-evidence) {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0 7px;
        margin-top: 5px;
        padding: 4px 8px;
        background: oklch(78% 0.08 40 / 0.22);
        border-left: 2px solid var(--sienna);
        border-radius: 0 2px 2px 0;
        font-family: var(--font-body);
        font-size: 0.74rem;
        line-height: 1.4;
        color: var(--ink-soft);
        max-width: 44ch;
      }
  :global(.bom-evidence::before) {
        content: 'label read';
        font-family: var(--font-mono);
        font-size: 0.58rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--sienna);
        font-weight: 600;
        align-self: center;
        margin-right: 2px;
        flex-shrink: 0;
      }
  :global(.bom-ev-quote) {
        display: inline-flex;
        align-items: baseline;
        font-family: 'Source Serif 4', 'Noto Serif CJK', 'Noto Sans CJK', 'PingFang SC', 'Hiragino Sans', serif;
        font-weight: 600;
        color: var(--ink);
      }
  :global(.bom-ev-mark) {
        color: var(--ink-mute);
        font-weight: 400;
        margin: 0 1px;
      }
  :global(.bom-ev-text) {
        font-style: italic;
        white-space: pre-wrap;
        /* Allow long serials to break; keep CJK from overflowing the cell */
        overflow-wrap: anywhere;
      }
  :global(.bom-ev-lang) {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-mute);
        align-self: center;
      }
  :global(.bom-ev-arrow) {
        color: var(--ink-mute);
        align-self: center;
      }
  :global(.bom-ev-translation) {
        font-style: italic;
        color: var(--ink-soft);
        font-weight: 500;
      }
  :global(.bom-ev-infl) {
        font-family: var(--font-mono);
        font-size: 0.66rem;
        color: var(--ink-mute);
        flex-basis: 100%;
        margin-top: 1px;
      }
  @media (max-width: 540px) {
      :global(.bom-evidence) { max-width: 100%; font-size: 0.7rem; }
      }

      /* Column: Qty */
:global(.bom-table td.col-num) {
        text-align: right;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1rem;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
      }

      /* Column: Material */
:global(.bom-table td.col-material) {
        font-size: 0.78rem;
        color: var(--ink-soft);
        font-family: var(--font-mono);
      }
:global(.bom-empty) { color: var(--ink-mute); font-style: italic; }

      /* Column: Confidence (bar + percentage) */
:global(.bom-conf) {
        display: flex; align-items: center; gap: 8px;
        justify-content: flex-end;
      }
:global(.bom-conf-track) {
        width: 70px;
        height: 4px;
        background: var(--paper-crease);
        border-radius: 1px;
        overflow: hidden;
      }
:global(.bom-conf-fill) {
        height: 100%;
        transition: width 500ms cubic-bezier(0.16, 1, 0.3, 1);
      }
:global(.bom-conf-fill.bom-conf-good) { background: var(--moss); }
:global(.bom-conf-fill.bom-conf-mid) { background: var(--amber); }
:global(.bom-conf-fill.bom-conf-low) { background: var(--rust); }
:global(.bom-conf-label) {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        font-weight: 500;
        min-width: 32px;
        text-align: right;
      }

      /* Column: Seen in (frame proof pill) */
:global(.bom-proof) {
        display: inline-flex; align-items: center; gap: 5px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--ink-soft);
        background: var(--paper);
        border: 1px solid var(--rule);
        padding: 3px 8px;
        border-radius: 2px;
        cursor: pointer;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.02em;
        transition: all 150ms ease;
        white-space: nowrap;
      }
:global(.bom-proof:hover) {
        background: var(--paper-edge);
        border-color: var(--sienna);
        color: var(--ink);
      }
:global(.bom-proof-dot) {
        width: 6px; height: 6px;
        background: var(--sienna);
        border-radius: 50%;
        flex-shrink: 0;
      }
:global(.bom-proof-ts) { color: var(--ink-mute); }

      /* Column: bomwiki link */
:global(.bom-table td.col-bomwiki) { text-align: right; }
:global(.bom-link) {
        display: inline-flex; align-items: center;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--paper);
        background: var(--ink);
        text-decoration: none;
        padding: 3px 8px;
        border-radius: 2px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 500;
        white-space: nowrap;
        transition: background 150ms ease;
      }
:global(.bom-link:hover) { background: var(--sienna); }
:global(.bom-link-empty) {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--ink-mute);
        font-style: italic;
        text-transform: none;
        letter-spacing: 0.02em;
        padding: 2px 6px;
        background: transparent;
        border: 1px dashed var(--rule);
        border-radius: 2px;
        white-space: nowrap;
      }

      /* Sticky active-frame bar at the top of the BOM card */
:global(.active-frame-bar) {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px;
        background: var(--sienna-soft);
        border-bottom: 1px solid var(--sienna);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--ink);
        position: sticky;
        top: 0;
        z-index: 5;
      }
:global(.active-frame-bar[hidden]) { display: none; }
:global(.active-frame-dot) {
        width: 8px; height: 8px;
        background: var(--sienna);
        border-radius: 50%;
        flex-shrink: 0;
        animation: dot-pulse 1.6s ease-in-out infinite;
      }
      @keyframes dot-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.5; transform: scale(0.8); }
      }
:global(.active-frame-label) {
        color: var(--ink-soft);
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
      }
:global(.active-frame-id) {
        font-weight: 600;
        color: var(--ink);
      }
:global(.active-frame-ts) {
        color: var(--ink-soft);
        font-variant-numeric: tabular-nums;
      }
:global(.active-frame-count) {
        color: var(--ink-soft);
        font-size: 0.68rem;
        margin-left: auto;
        padding: 2px 8px;
        background: var(--paper);
        border: 1px solid var(--sienna);
        border-radius: 2px;
      }
:global(.active-frame-clear) {
        background: transparent;
        border: 1px solid var(--sienna);
        color: var(--sienna);
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 3px 8px;
        border-radius: 2px;
        cursor: pointer;
        transition: all 150ms ease;
      }
:global(.active-frame-clear:hover) {
        background: var(--sienna);
        color: var(--paper);
      }

      /* Frame tile sticky "selected" state (matches the sticky bar) */
:global(.frame-tile.is-selected) {
        border-color: var(--sienna);
        box-shadow: 0 0 0 2px var(--sienna);
      }
:global(.frame-tile.is-pulsing) {
        animation: tile-pulse 600ms ease;
      }
      @keyframes tile-pulse {
        0%   { transform: scale(1); box-shadow: 0 0 0 0 oklch(58% 0.18 35 / 0.5); }
        50%  { transform: scale(1.04); box-shadow: 0 0 0 6px oklch(58% 0.18 35 / 0.2); }
        100% { transform: scale(1); box-shadow: 0 0 0 2px var(--sienna); }
      }

      /* ---- Bottom row ---- */
      .result-bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--s-4);
      }
      @media (max-width: 760px) { .result-bottom { grid-template-columns: 1fr; } }

      .geometry-grid {
        padding: var(--s-3) var(--s-4) var(--s-4);
        display: flex; flex-direction: column;
        gap: var(--s-2);
      }
      .geo-row {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: var(--s-3);
        padding: 6px 0;
        border-bottom: 1px dashed var(--rule-soft);
        font-size: 0.875rem;
      }
      .geo-row:last-child { border-bottom: 0; }
      .geo-k {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-mute);
        font-weight: 600;
        align-self: center;
      }
      .geo-v { color: var(--ink); font-weight: 500; }
      .empty-line { color: var(--ink-mute); font-style: italic; margin: 0; }

      .meta-notes {
        margin: 0;
        padding: var(--s-3) var(--s-4) var(--s-4);
        font-size: 0.875rem;
        color: var(--ink-soft);
        line-height: 1.55;
        font-style: italic;
      }

      .result-actions { display: flex; gap: var(--s-2); }

      /* ---- Focus rings ---- */
      button:focus-visible, a:focus-visible {
        outline: 2px solid var(--sienna);
        outline-offset: 3px;
      }

      /* ---- Subtle entrance ---- */
      @media (prefers-reduced-motion: no-preference) {
        .stage { animation: fade-in 400ms ease both; }
      }
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </body>
</html>
