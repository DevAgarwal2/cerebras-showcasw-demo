---
const model = import.meta.env.GEMMA_MODEL ?? 'gemma-4-31b-it';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Bill of Vision — Video → Bill of Materials</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-grain" aria-hidden="true"></div>

    <main class="shell">
      <header class="masthead">
        <div class="masthead-left">
          <div class="seal" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="32" height="32">
              <circle cx="16" cy="16" r="14.5" fill="none" stroke="currentColor" stroke-width="1" />
              <circle cx="16" cy="16" r="9" fill="none" stroke="currentColor" stroke-width="1" />
              <path d="M16 2 L16 30 M2 16 L30 16" stroke="currentColor" stroke-width="0.5" />
              <text x="16" y="19" text-anchor="middle" font-family="Bricolage Grotesque" font-size="9" font-weight="700" fill="currentColor">BoV</text>
            </svg>
          </div>
          <div class="masthead-text">
            <h1 class="title">Bill of Vision</h1>
            <p class="kicker">A video in. A bill of materials out.</p>
          </div>
        </div>
      </header>

      <!-- ========== STAGE A: UPLOAD (or video preview after selection) ========== -->
      <section id="stage-upload" class="stage stage-upload">
        <div id="upload-zone" class="upload-zone">
          <input type="file" id="video-input" accept="video/mp4,video/webm,video/quicktime,video/*" hidden />
          <div class="upload-inner" id="upload-inner">
            <div class="upload-mark" aria-hidden="true">
              <svg viewBox="0 0 48 48" width="48" height="48">
                <rect x="6" y="10" width="36" height="26" rx="2" fill="none" stroke="currentColor" stroke-width="1.5" />
                <path d="M6 28 L20 20 L28 24 L42 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <circle cx="34" cy="18" r="2" fill="currentColor" />
                <path d="M22 42 L26 42 M24 36 L24 42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <p class="upload-text">Drop a video into the frame, or <button type="button" id="browse" class="text-link">browse the cabinet</button>.</p>
            <p class="upload-hint">MP4 · WebM · MOV &nbsp;·&nbsp; up to 100&nbsp;MB &nbsp;·&nbsp; best under 45s</p>
            <div class="sample-shelf">
              <span class="shelf-label">Or open a specimen:</span>
              <div class="sample-buttons">
                <button type="button" class="specimen-btn" data-sample="/samples/nameplate-jp.mp4" data-name="nameplate-jp"><span class="specimen-emoji">🈁</span> Kanji Nameplate</button>
                <button type="button" class="specimen-btn" data-sample="/samples/excavator.mp4" data-name="excavator"><span class="specimen-emoji">🏗</span> Excavator</button>
                <button type="button" class="specimen-btn" data-sample="/samples/komatsu-jp.mp4" data-name="komatsu-jp"><span class="specimen-emoji">🇯🇵</span> Komatsu JP (nameplate)</button>
                <button type="button" class="specimen-btn" data-sample="/samples/car-engine.mp4" data-name="car-engine"><span class="specimen-emoji">🚗</span> Car Engine</button>
                <button type="button" class="specimen-btn" data-sample="/samples/cnc-machine.mp4" data-name="cnc"><span class="specimen-emoji">🏭</span> Mazak VMC</button>
                <button type="button" class="specimen-btn" data-sample="/samples/factory-robots.mp4" data-name="factory-robots"><span class="specimen-emoji">🤖</span> Factory Robots</button>
                <button type="button" class="specimen-btn" data-sample="/samples/robot-welding.mp4" data-name="robot-welding"><span class="specimen-emoji">🔧</span> Robot Welding</button>
                <button type="button" class="specimen-btn" data-sample="/samples/3d-printer.mp4" data-name="3d-printer"><span class="specimen-emoji">🖨</span> 3D Printer</button>
                <button type="button" class="specimen-btn" data-sample="/samples/surgical-robot.mp4" data-name="surgical-robot"><span class="specimen-emoji">🏥</span> Surgical Robot</button>
                <button type="button" class="specimen-btn" data-sample="/samples/mri-scanner.mp4" data-name="mri-scanner"><span class="specimen-emoji">📡</span> MRI Scanner</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Video preview + frame plan (revealed after file selected) -->
        <div id="preview-zone" class="preview-zone" hidden>
          <div class="preview-header">
            <div class="preview-meta">
              <span class="kicker">Loaded specimen</span>
              <span class="preview-name" id="preview-name">—</span>
            </div>
            <div class="preview-stats" id="preview-stats">
              <span class="stat-chip"><span class="chip-lbl">Size</span><span class="chip-val" id="preview-size">—</span></span>
              <span class="stat-chip"><span class="chip-lbl">Format</span><span class="chip-val" id="preview-type">—</span></span>
            </div>
            <button type="button" id="reset-preview" class="ghost-btn">Choose a different video</button>
          </div>
          <div class="preview-body">
            <div class="video-frame">
              <video id="video-preview" controls preload="metadata" playsinline crossorigin="anonymous"></video>
            </div>
            <aside class="frame-strip-wrap">
              <div class="frame-strip-head">
                <span class="kicker">Extraction plan</span>
                <p class="strip-explain">Twelve frames will be lifted from this video and sent to the four agents. We sample evenly across the middle 90% of the clip &mdash; skipping fades and outros.</p>
              </div>
              <div class="frame-strip" id="frame-strip">
                {Array.from({ length: 12 }).map((_, i) => (
                  <div class="frame-slot" data-index={i}>
                    <span class="frame-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="frame-ts" data-ts>—</span>
                  </div>
                ))}
              </div>
              <button type="button" id="run-btn" class="run-btn">
                <span class="run-btn-label">Run the four agents</span>
                <span class="run-btn-arrow" aria-hidden="true">→</span>
              </button>
            </aside>
          </div>
        </div>
      </section>

      <!-- ========== STAGE B: PROGRESS ========== -->
      <section id="stage-progress" class="stage stage-progress" hidden>
        <div class="progress-head">
          <div>
            <span class="kicker">Pipeline running</span>
            <h2 class="progress-title" id="progress-title">Working on your specimen…</h2>
          </div>
          <div class="progress-summary">
            <span class="kicker">Live status</span>
            <span class="progress-status" id="progress-status">Warming up…</span>
          </div>
        </div>

        <ol class="agents-board" id="agents-board">
          <li class="agent-card" data-agent="detector">
            <div class="agent-head">
              <span class="agent-ord">01</span>
              <span class="agent-icon" aria-hidden="true">◐</span>
              <span class="agent-name">Part Detector</span>
            </div>
            <p class="agent-brief">Identifies every visible component across the twelve frames.</p>
            <p class="agent-summary" data-summary></p>
            <div class="agent-foot">
              <span class="agent-status">queued</span>
              <span class="agent-latency"></span>
            </div>
            <div class="agent-bar"><div class="agent-bar-fill"></div></div>
          </li>
          <li class="agent-card" data-agent="geometry">
            <div class="agent-head">
              <span class="agent-ord">02</span>
              <span class="agent-icon" aria-hidden="true">◑</span>
              <span class="agent-name">Geometry Agent</span>
            </div>
            <p class="agent-brief">Estimates scale, dimensions, mass, and dominant materials.</p>
            <p class="agent-summary" data-summary></p>
            <div class="agent-foot">
              <span class="agent-status">queued</span>
              <span class="agent-latency"></span>
            </div>
            <div class="agent-bar"><div class="agent-bar-fill"></div></div>
          </li>
          <li class="agent-card" data-agent="mapper">
            <div class="agent-head">
              <span class="agent-ord">03</span>
              <span class="agent-icon" aria-hidden="true">◒</span>
              <span class="agent-name">BOM Mapper</span>
            </div>
            <p class="agent-brief">Resolves each part name to a canonical <a href="https://bomwiki.com" target="_blank" rel="noreferrer">bomwiki.com</a> slug.</p>
            <p class="agent-summary" data-summary></p>
            <div class="agent-foot">
              <span class="agent-status">queued</span>
              <span class="agent-latency"></span>
            </div>
            <div class="agent-bar"><div class="agent-bar-fill"></div></div>
          </li>
          <li class="agent-card" data-agent="reporter">
            <div class="agent-head">
              <span class="agent-ord">04</span>
              <span class="agent-icon" aria-hidden="true">◓</span>
              <span class="agent-name">Report Builder</span>
            </div>
            <p class="agent-brief">Stitches parts, geometry, and bomwiki links into a hierarchical BOM, then re-ranks every URL.</p>
            <p class="agent-summary" data-summary></p>
            <div class="agent-foot">
              <span class="agent-status">queued</span>
              <span class="agent-latency"></span>
            </div>
            <div class="agent-bar"><div class="agent-bar-fill"></div></div>
          </li>
        </ol>

        <div class="progress-foot">
          <span class="kicker">Flow</span>
          <p class="flow-line" id="flow-line">Frames are being lifted from the video with ffmpeg. Then four agents run on them.</p>
        </div>
      </section>

      <!-- ========== STAGE C: RESULT ========== -->
      <section id="stage-result" class="stage stage-result" hidden>
        <!-- Product hero — single scannable row: image left, text right -->
        <header class="result-hero">
          <figure class="hero-art" id="hero-art">
            <div class="hero-art-fallback" id="hero-art-fallback">
              <span class="kicker">Product</span>
              <span class="hero-art-loading">looking up bomwiki.com…</span>
            </div>
          </figure>
          <div class="hero-text">
            <span class="kicker">Identified specimen</span>
            <h2 id="r-product" class="result-product">—</h2>
            <p id="r-summary" class="result-summary">—</p>
            <dl class="hero-stats">
              <div class="hero-stat">
                <dt class="hero-stat-lbl">Parts</dt>
                <dd class="hero-stat-num" id="r-total">0</dd>
              </div>
              <div class="hero-stat">
                <dt class="hero-stat-lbl">Time</dt>
                <dd class="hero-stat-num" id="r-time">0<span class="hero-stat-unit">s</span></dd>
              </div>
              <div class="hero-stat">
                <dt class="hero-stat-lbl">Frames</dt>
                <dd class="hero-stat-num" id="r-frames">0</dd>
              </div>
              <div class="hero-stat">
                <dt class="hero-stat-lbl">Sub-assemblies</dt>
                <dd class="hero-stat-num" id="r-groups">0</dd>
              </div>
            </dl>
          </div>
        </header>

        <!-- Frame strip — compact, single row, 6 cols, hover-to-zoom -->
        <section class="frames-card">
          <header class="card-head">
            <h3>What the agents saw</h3>
            <span class="card-sub" id="frames-sub">12 frames lifted from the video</span>
          </header>
          <div class="frames-strip" id="frames-strip">
            {Array.from({ length: 12 }).map((_, i) => (
              <figure class="frame-tile" data-index={i}>
                <div class="frame-tile-img" data-thumb>
                  <span class="frame-tile-num">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <figcaption class="frame-tile-cap">
                  <span class="frame-tile-ts" data-ts>—</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </section>

        <!-- BOM — the main event -->
        <section class="bom-card">
          <header class="card-head">
            <h3>Bill of Materials</h3>
            <span class="card-sub" id="bom-sub">—</span>
          </header>
          <!-- Sticky active-frame indicator. Hidden by default; shown when
               the user clicks a frame tile. Sticks to the top of the card
               while scrolling, so the user always knows which frame they
               last clicked. -->
          <div id="active-frame-bar" class="active-frame-bar" hidden>
            <span class="active-frame-dot" aria-hidden="true"></span>
            <span class="active-frame-label">Showing parts from</span>
            <span class="active-frame-id" id="active-frame-id">frame 00</span>
            <span class="active-frame-ts" id="active-frame-ts">—</span>
            <span class="active-frame-count" id="active-frame-count">0 parts</span>
            <button type="button" id="active-frame-clear" class="active-frame-clear">clear</button>
          </div>
          <div id="bom-tree" class="bom-tree"></div>
        </section>

        <!-- Footer row: geometry + notes, side by side -->
        <div class="result-bottom">
          <article class="meta-card">
            <header class="card-head">
              <h3>Geometry</h3>
            </header>
            <div class="geometry-grid" id="r-geometry">
              <p class="empty-line">—</p>
            </div>
          </article>
          <article class="meta-card">
            <header class="card-head">
              <h3>Notes from the run</h3>
            </header>
            <p class="meta-notes" id="r-notes">—</p>
          </article>
        </div>

        <div class="result-actions">
          <button type="button" id="new-run" class="ghost-btn">Run a different video</button>
          <button type="button" id="export-json" class="ghost-btn">Export full result as JSON</button>
        </div>
      </section>
    </main>

    <footer class="colophon">
      <div class="colophon-inner">
        <span>Bill of Vision</span>
        <span class="colophon-dot">·</span>
        <span>Model <code>{model}</code></span>
        <span class="colophon-dot">·</span>
        <span>4-agent pipeline</span>
        <span class="colophon-dot">·</span>
        <span>176,882 bomwiki slugs</span>
        <span class="colophon-dot">·</span>
        <span>Built for a hackathon.</span>
      </div>
    </footer>

    <script>
      type AgentName = 'detector' | 'geometry' | 'mapper' | 'reporter';
      type Stage = 'upload' | 'progress' | 'result';

      // ---- DOM ----
      const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
      const stageUpload = $('stage-upload');
      const stageProgress = $('stage-progress');
      const stageResult = $('stage-result');
      const uploadZone = $('upload-zone');
      const uploadInner = $('upload-inner');
      const browseBtn = $('browse');
      const videoInput = $<HTMLInputElement>('video-input');
      const previewZone = $('preview-zone');
      const videoPreview = $<HTMLVideoElement>('video-preview');
      const previewName = $('preview-name');
      const previewSize = $('preview-size');
      const previewType = $('preview-type');
      const resetPreview = $('reset-preview');
      const runBtn = $('run-btn');
      const frameStrip = $('frame-strip');
      const newRunBtn = $('new-run');
      const exportJsonBtn = $('export-json');
      const progressStatus = $('progress-status');
      const progressTitle = $('progress-title');
      const flowLine = $('flow-line');

      let pendingFile: File | null = null;
      let pendingObjectUrl: string | null = null;
      let lastResult: any = null;
      let extractionTimestamps: number[] = [];

      // ---- Agent card state ----
      function setAgent(name: AgentName, status: 'queued' | 'running' | 'done' | 'error', latency = '', summary = '') {
        const card = document.querySelector(`[data-agent="${name}"]`);
        if (!card) return;
        card.classList.remove('is-queued', 'is-running', 'is-done', 'is-error');
        card.classList.add(`is-${status}`);
        const statusEl = card.querySelector('.agent-status') as HTMLElement;
        const latEl = card.querySelector('.agent-latency') as HTMLElement;
        const summaryEl = card.querySelector('[data-summary]') as HTMLElement;
        const fill = card.querySelector('.agent-bar-fill') as HTMLElement;
        statusEl.textContent = status;
        latEl.textContent = latency;
        summaryEl.textContent = summary;
        if (status === 'done') fill.style.width = '100%';
        else if (status === 'running') fill.style.width = '55%';
        else if (status === 'error') fill.style.width = '100%';
        else fill.style.width = '4%';
      }

      function resetAgents() {
        (['detector', 'geometry', 'mapper', 'reporter'] as AgentName[]).forEach((n) =>
          setAgent(n, 'queued', '', '')
        );
      }

      function showStage(s: Stage) {
        stageUpload.hidden = s !== 'upload';
        stageProgress.hidden = s !== 'progress';
        stageResult.hidden = s !== 'result';
        if (s === 'result') {
          stageResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      // ---- File selection ----
      function humanSize(bytes: number): string {
        if (bytes < 1024) return `${bytes} B`;
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
        return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
      }

      function planTimestamps(duration: number, frameCount = 12): number[] {
        const startOffset = Math.min(0.5, duration * 0.05);
        const endOffset = Math.max(startOffset + 0.1, duration - duration * 0.05);
        const usable = Math.max(0.1, endOffset - startOffset);
        const out: number[] = [];
        for (let i = 0; i < frameCount; i++) {
          const t = startOffset + (usable * i) / Math.max(1, frameCount - 1);
          out.push(Number(t.toFixed(2)));
        }
        return out;
      }

      function showPreview(file: File) {
        pendingFile = file;
        if (pendingObjectUrl) URL.revokeObjectURL(pendingObjectUrl);
        pendingObjectUrl = URL.createObjectURL(file);
        videoPreview.src = pendingObjectUrl;
        previewName.textContent = file.name;
        previewSize.textContent = humanSize(file.size);
        previewType.textContent = (file.type || 'video/mp4').replace('video/', '').toUpperCase();
        uploadZone.hidden = true;
        previewZone.hidden = false;
        frameStrip.querySelectorAll<HTMLElement>('.frame-ts').forEach((el) => (el.textContent = '—'));
        videoPreview.load();
      }

      function resetToUpload() {
        pendingFile = null;
        if (pendingObjectUrl) URL.revokeObjectURL(pendingObjectUrl);
        pendingObjectUrl = null;
        videoPreview.removeAttribute('src');
        videoPreview.load();
        videoInput.value = '';
        uploadZone.hidden = false;
        previewZone.hidden = true;
        showStage('upload');
      }

      videoPreview.addEventListener('loadedmetadata', () => {
        const d = videoPreview.duration;
        if (!isFinite(d) || d <= 0) return;
        extractionTimestamps = planTimestamps(d, 12);
        const slots = frameStrip.querySelectorAll<HTMLElement>('.frame-ts');
        slots.forEach((el, i) => {
          el.textContent = `${extractionTimestamps[i].toFixed(1)}s`;
        });
      });

      browseBtn.addEventListener('click', () => videoInput.click());
      uploadInner.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.specimen-btn')) return;
        videoInput.click();
      });

      document.querySelectorAll<HTMLButtonElement>('.specimen-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const url = btn.dataset.sample!;
          const name = btn.dataset.name ?? 'sample.mp4';
          progressStatus.textContent = `Fetching ${name}…`;
          showStage('upload');
          resetToUpload();
          try {
            const res = await fetch(url);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const blob = await res.blob();
            const file = new File([blob], `${name}.mp4`, { type: blob.type || 'video/mp4' });
            showPreview(file);
          } catch (err) {
            progressStatus.textContent = `Could not load sample: ${err instanceof Error ? err.message : String(err)}`;
          }
        });
      });

      ['dragover', 'dragenter'].forEach((ev) => {
        uploadZone.addEventListener(ev, (e) => {
          e.preventDefault();
          uploadZone.classList.add('is-dragging');
        });
      });
      ['dragleave', 'drop'].forEach((ev) => {
        uploadZone.addEventListener(ev, () => uploadZone.classList.remove('is-dragging'));
      });
      uploadZone.addEventListener('drop', (e) => {
        e.preventDefault();
        const file = e.dataTransfer?.files?.[0];
        if (file) showPreview(file);
      });
      videoInput.addEventListener('change', () => {
        const f = videoInput.files?.[0];
        if (f) showPreview(f);
      });

      resetPreview.addEventListener('click', resetToUpload);
      runBtn.addEventListener('click', () => {
        if (pendingFile) runPipeline(pendingFile);
      });
      newRunBtn.addEventListener('click', resetToUpload);
      exportJsonBtn.addEventListener('click', () => {
        if (!lastResult) return;
        const blob = new Blob([JSON.stringify(lastResult, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `bom-${(lastResult.product || 'report').toString().toLowerCase().replace(/\s+/g, '-')}.json`;
        a.click();
        URL.revokeObjectURL(url);
      });

      // ---- Pipeline (SSE) ----
      async function runPipeline(file: File) {
        showStage('progress');
        resetAgents();
        progressStatus.textContent = 'Warming up…';
        progressTitle.textContent = 'Working on your specimen…';
        flowLine.textContent = 'Frames are being lifted from the video with ffmpeg. Then four agents run on them.';

        const fd = new FormData();
        fd.append('video', file);

        let res: Response;
        try {
          res = await fetch('/api/bom', { method: 'POST', body: fd });
        } catch (e) {
          progressStatus.textContent = `Network error: ${e instanceof Error ? e.message : String(e)}`;
          return;
        }
        if (!res.ok && !res.headers.get('content-type')?.includes('text/event-stream')) {
          try {
            const err = await res.json();
            progressStatus.textContent = `Error: ${err.error ?? res.statusText}`;
          } catch {
            progressStatus.textContent = `Error: HTTP ${res.status}`;
          }
          return;
        }

        const reader = res.body!.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        let resultEvent: any = null;
        let errored = false;

        try {
          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            buf += decoder.decode(value, { stream: true });
            // SSE events are separated by blank lines
            let idx: number;
            while ((idx = buf.indexOf('\n\n')) !== -1) {
              const raw = buf.slice(0, idx);
              buf = buf.slice(idx + 2);
              const ev = parseSSE(raw);
              if (!ev) continue;
              handleEvent(ev);
              if (ev.event === 'result') resultEvent = ev.data;
              if (ev.event === 'error') errored = true;
            }
          }
        } catch (e) {
          progressStatus.textContent = `Stream error: ${e instanceof Error ? e.message : String(e)}`;
          return;
        }

        if (errored) return;
        if (resultEvent) {
          lastResult = resultEvent;
          renderResult(resultEvent);
        } else {
          progressStatus.textContent = 'Pipeline ended without a result.';
        }
      }

      function parseSSE(raw: string): { event: string; data: any } | null {
        let event = 'message';
        const dataLines: string[] = [];
        for (const line of raw.split('\n')) {
          if (line.startsWith('event:')) event = line.slice(6).trim();
          else if (line.startsWith('data:')) dataLines.push(line.slice(5).trim());
        }
        if (dataLines.length === 0) return null;
        try {
          return { event, data: JSON.parse(dataLines.join('\n')) };
        } catch {
          return { event, data: dataLines.join('\n') };
        }
      }

      function handleEvent(ev: { event: string; data: any }) {
        if (ev.event === 'status') {
          const { phase, text } = ev.data as { phase: string; text: string };
          progressStatus.textContent = text;
          flowLine.textContent = text;
          progressTitle.textContent = humanizePhase(phase);
          return;
        }
        if (ev.event === 'frames') {
          const { count, extractMs } = ev.data as { count: number; extractMs: number };
          flowLine.textContent = `Lifted ${count} frames in ${(extractMs / 1000).toFixed(1)}s. Handing them to the four agents.`;
          return;
        }
        if (ev.event === 'agent') {
          const { name, status, latency_ms, summary } = ev.data as { name: AgentName; status: 'queued' | 'running' | 'done' | 'error'; latency_ms?: number; summary?: string };
          const lat = latency_ms && latency_ms > 0 ? `${(latency_ms / 1000).toFixed(1)}s` : '';
          setAgent(name, status, lat, summary ?? '');
          return;
        }
        if (ev.event === 'error') {
          progressStatus.textContent = `Error: ${ev.data.error ?? 'Unknown'}`;
          (['detector', 'geometry', 'mapper', 'reporter'] as AgentName[]).forEach((n) =>
            setAgent(n, 'error', '—', '')
          );
          return;
        }
      }

      function humanizePhase(phase: string): string {
        switch (phase) {
          case 'extract': return 'Lifting frames from the video…';
          case 'phase1': return 'Detector and Geometry are running in parallel…';
          case 'phase1b': return 'Mapper is resolving parts against bomwiki.com…';
          case 'phase2': return 'Report Builder is composing the final BOM…';
          default: return 'Working on your specimen…';
        }
      }

      // ---- Result rendering ----
      async function renderResult(data: any) {
        // Hero
        $('r-product').textContent = data.product ?? '—';
        $('r-summary').textContent = data.summary ?? '—';
        $('r-total').textContent = String(data.total_parts ?? 0);
        $('r-time').innerHTML = `${(data.timing.total_ms / 1000).toFixed(1)}<span class="hero-stat-unit">s</span>`;
        $('r-frames').textContent = String(data.frame_count ?? 0);
        const bom = data.bom ?? [];
        const groupCount = new Set(bom.map((b: any) => b.sub_assembly || 'Other')).size;
        $('r-groups').textContent = String(groupCount);

        // Frame strip — capture from the preview video
        await renderFrameStrip();

        // Product image lookup — try the bomwiki thumb URL directly.
        // No server probe needed: <img> onload/onerror does the work.
        const productSlug = slugify(data.product ?? '');
        renderProductImage($('hero-art'), data.product ?? '—', productSlug);

        // BOM tree — per-part cards
        const tree = $('bom-tree');
        tree.innerHTML = '';
        $('bom-sub').textContent =
          bom.length === 0
            ? 'No parts returned'
            : `${bom.length} entries across ${groupCount} sub-assemblies`;

        const groups: Record<string, any[]> = {};
        bom.forEach((item: any) => {
          const g = item.sub_assembly || 'Miscellaneous';
          (groups[g] ??= []).push(item);
        });
        const groupNames = Object.keys(groups).sort((a, b) => groups[b].length - groups[a].length);
        groupNames.forEach((group) => {
          const items = groups[group];
          const groupEl = document.createElement('section');
          groupEl.className = 'bom-group';
          const head = document.createElement('header');
          head.className = 'bom-group-head';
          head.innerHTML = `<h4>${escape(group)}</h4><span class="bom-group-count">${items.length} part${items.length === 1 ? '' : 's'}</span>`;
          groupEl.appendChild(head);
          const table = buildBomTable(items);
          groupEl.appendChild(table);
          tree.appendChild(groupEl);
        });

        // Geometry grid (prose, not JSON)
        renderGeometry(data.geometry);

        // Notes
        $('r-notes').textContent = data.notes ?? 'No additional notes.';

        // Subtitle on the frame strip
        $('frames-sub').textContent = `${data.frame_count ?? 12} frames lifted from the video and passed to the four agents`;

        // Make the frame strip interactive: clicking a frame tile scrolls
        // down to the parts that the agent identified from that frame and
        // briefly highlights them. The reverse direction (part card →
        // frame) is wired up inside buildPartCard.
        wireFrameStrip();

        showStage('result');
      }

      // Build a real <table> for a sub-assembly. Columns: Part · Qty ·
      // Material · Confidence · Seen in · bomwiki. Rows are tagged with
      // data-frame-index so the frame-strip click handler can find them.
      function buildBomTable(items: any[]): HTMLElement {
        const wrap = document.createElement('div');
        wrap.className = 'bom-table-wrap';

        const table = document.createElement('table');
        table.className = 'bom-table';

        // Header
        const thead = document.createElement('thead');
        const trh = document.createElement('tr');
        const cols = ['Part', 'Qty', 'Material', 'Confidence', 'Seen in', 'bomwiki'];
        for (const label of cols) {
          const th = document.createElement('th');
          th.textContent = label;
          if (label === 'Qty') th.className = 'col-num';
          if (label === 'Confidence') th.className = 'col-conf';
          if (label === 'Seen in') th.className = 'col-frame';
          if (label === 'bomwiki') th.className = 'col-bomwiki';
          trh.appendChild(th);
        }
        thead.appendChild(trh);
        table.appendChild(thead);

        // Body
        const tbody = document.createElement('tbody');
        for (const it of items) {
          tbody.appendChild(buildPartRow(it));
        }
        table.appendChild(tbody);

        wrap.appendChild(table);
        return wrap;
      }

      function buildPartRow(it: any): HTMLTableRowElement {
        const tr = document.createElement('tr');
        tr.className = 'bom-row';

        // Tag the row with the frame index so the frame-strip click
        // handler can find all parts that came from this frame.
        if (typeof it.frame_index === 'number') {
          tr.dataset.frameIndex = String(it.frame_index);
        }

        const partConf = (it.confidence ?? 0);
        const confPct = Math.round(partConf * 100);
        const confTone = partConf >= 0.7 ? 'good' : partConf >= 0.5 ? 'mid' : 'low';
        const slug = it.bomwiki_url ? extractSlug(it.bomwiki_url) : '';
        const qty = it.quantity ?? 1;

        // Cell 1: Part name + note + art (try bomwiki thumb, fall back to initials)
        const partCell = document.createElement('td');
        partCell.className = 'col-part';
        const partInner = document.createElement('div');
        partInner.className = 'bom-part-inner';
        const art = document.createElement('div');
        art.className = 'bom-art';
        const fallback = document.createElement('div');
        fallback.className = 'bom-art-fallback';
        fallback.innerHTML = `<span class="bom-art-initials">${escape(initials(it.name))}</span>`;
        art.appendChild(fallback);
        partInner.appendChild(art);
        const text = document.createElement('div');
        text.className = 'bom-text';
        const name = document.createElement('div');
        name.className = 'bom-name';
        name.textContent = it.name ?? 'Unnamed part';
        text.appendChild(name);
        if (it.note) {
          const note = document.createElement('div');
          note.className = 'bom-note';
          note.textContent = it.note;
          text.appendChild(note);
        }
        // Multilingual evidence — only render when the Detector actually
        // read text off a nameplate/label. Empty strings are skipped so a
        // part with no readable label shows nothing (never a "—").
        if (it.detected_text) {
          text.appendChild(buildEvidenceLine(it));
        }
        partInner.appendChild(text);
        partCell.appendChild(partInner);
        tr.appendChild(partCell);

        if (slug || it.name) {
          findImage({
            primarySlug: slug,
            nameForSearch: it.name ?? '',
            categoryForSearch: categoryForCommons(it),
          }).then((url) => {
            if (!url) return;
            art.innerHTML = '';
            const img = document.createElement('img');
            img.src = url;
            img.alt = it.name ?? '';
            img.loading = 'lazy';
            img.decoding = 'async';
            art.appendChild(img);
            art.classList.add('has-image');
          });
        }

        // Cell 2: Qty (right-aligned, tabular)
        const qtyCell = document.createElement('td');
        qtyCell.className = 'col-num';
        qtyCell.textContent = String(qty);
        tr.appendChild(qtyCell);

        // Cell 3: Material (muted text or chip)
        const matCell = document.createElement('td');
        matCell.className = 'col-material';
        matCell.textContent = it.material || '—';
        tr.appendChild(matCell);

        // Cell 4: Confidence bar + percentage
        const confCell = document.createElement('td');
        confCell.className = 'col-conf';
        const confWrap = document.createElement('div');
        confWrap.className = 'bom-conf';
        const track = document.createElement('div');
        track.className = 'bom-conf-track';
        const fill = document.createElement('div');
        fill.className = `bom-conf-fill bom-conf-${confTone}`;
        fill.style.width = `${Math.max(4, confPct)}%`;
        track.appendChild(fill);
        confWrap.appendChild(track);
        const confLabel = document.createElement('span');
        confLabel.className = 'bom-conf-label';
        confLabel.textContent = `${confPct}%`;
        confWrap.appendChild(confLabel);
        confCell.appendChild(confWrap);
        tr.appendChild(confCell);

        // Cell 5: Frame proof (clickable, scrolls to the frame tile)
        const frameCell = document.createElement('td');
        frameCell.className = 'col-frame';
        if (typeof it.frame_index === 'number') {
          const proof = document.createElement('button');
          proof.type = 'button';
          proof.className = 'bom-proof';
          const ts = typeof it.frame_timestamp === 'number'
            ? `${it.frame_timestamp.toFixed(1)}s`
            : '';
          proof.innerHTML = `<span class="bom-proof-dot" aria-hidden="true"></span>frame ${String(it.frame_index + 1).padStart(2, '0')}${ts ? ` <span class="bom-proof-ts">${ts}</span>` : ''}`;
          proof.title = `This part was identified in frame ${it.frame_index + 1} at ${ts || '?'}`;
          proof.addEventListener('click', () => {
            setActiveFrame(String(it.frame_index));
            const tile = document.querySelector(`#frames-strip .frame-tile[data-index="${it.frame_index}"]`);
            if (tile) {
              tile.scrollIntoView({ behavior: 'smooth', block: 'center' });
              tile.classList.add('is-pulsing');
              setTimeout(() => tile.classList.remove('is-pulsing'), 600);
            }
          });
          frameCell.appendChild(proof);
        } else {
          frameCell.innerHTML = '<span class="bom-empty">—</span>';
        }
        tr.appendChild(frameCell);

        // Cell 6: bomwiki link
        const linkCell = document.createElement('td');
        linkCell.className = 'col-bomwiki';
        if (it.bomwiki_url) {
          const link = document.createElement('a');
          link.className = 'bom-link';
          link.href = it.bomwiki_url;
          link.target = '_blank';
          link.rel = 'noreferrer';
          link.textContent = 'bomwiki ↗';
          link.title = it.bomwiki_url;
          linkCell.appendChild(link);
        } else {
          linkCell.innerHTML = '<span class="bom-link-empty">no entry</span>';
        }
        tr.appendChild(linkCell);

        return tr;
      }

      // Multilingual evidence line — renders the verbatim nameplate reading
      // the Detector pulled off the part, with its language, the English
      // translation, and one short clause on how reading it influenced
      // the match. Only shown when detected_text is non-empty, so parts
      // with no legible label render nothing (never a placeholder dash).
      function buildEvidenceLine(it: any): HTMLElement {
        const wrap = document.createElement('div');
        wrap.className = 'bom-evidence';

        const quote = document.createElement('span');
        quote.className = 'bom-ev-quote';
        wrap.appendChild(quote);

        const mark = document.createElement('span');
        mark.className = 'bom-ev-mark';
        mark.textContent = '「';
        quote.appendChild(mark);

        const txt = document.createElement('span');
        txt.className = 'bom-ev-text';
        const isForeign = it.detected_language && it.detected_language.toLowerCase() !== 'english';
        if (isForeign) txt.setAttribute('lang', langCode(it.detected_language));
        txt.textContent = String(it.detected_text);
        quote.appendChild(txt);

        const markClose = document.createElement('span');
        markClose.className = 'bom-ev-mark';
        markClose.textContent = '」';
        quote.appendChild(markClose);

        if (it.detected_language) {
          const lang = document.createElement('span');
          lang.className = 'bom-ev-lang';
          lang.textContent = it.detected_language;
          wrap.appendChild(lang);
        }

        if (it.translation) {
          const arrow = document.createElement('span');
          arrow.className = 'bom-ev-arrow';
          arrow.textContent = '→';
          wrap.appendChild(arrow);
          const tr = document.createElement('span');
          tr.className = 'bom-ev-translation';
          tr.textContent = `"${it.translation}"`;
          wrap.appendChild(tr);
        }

        if (it.detection_influence) {
          const infl = document.createElement('span');
          infl.className = 'bom-ev-infl';
          infl.textContent = `· ${it.detection_influence}`;
          wrap.appendChild(infl);
        }

        return wrap;
      }

      // Map a human language name to an ISO/BCP-47 lang code so the browser
      // uses the right font fallback for CJK / Arabic / etc.
      function langCode(name: string): string {
        const n = String(name).toLowerCase();
        const map: Record<string, string> = {
          japanese: 'ja', '日本語': 'ja',
          chinese: 'zh', '中文': 'zh', mandarin: 'zh', cantonese: 'zh-yue',
          korean: 'ko', '한국어': 'ko',
          arabic: 'ar', 'العربية': 'ar',
          russian: 'ru', 'русский': 'ru',
          german: 'de', french: 'fr', spanish: 'es', italian: 'it',
          portuguese: 'pt', thai: 'th', 'ภาษาไทย': 'th',
          hindi: 'hi', hebrew: 'he', greek: 'el',
        };
        return map[n] ?? 'und';
      }

      function renderGeometry(g: any) {
        const target = $('r-geometry');
        target.innerHTML = '';
        if (!g) {
          target.innerHTML = '<p class="empty-line">No geometry data returned.</p>';
          return;
        }
        const rows: Array<[string, string]> = [];
        if (g.scale_class) rows.push(['Scale class', g.scale_class]);
        if (g.environment) rows.push(['Used in', g.environment]);
        if (g.estimated_length_mm) rows.push(['Length', `${(g.estimated_length_mm / 1000).toFixed(2)} m`]);
        if (g.estimated_width_mm) rows.push(['Width', `${(g.estimated_width_mm / 1000).toFixed(2)} m`]);
        if (g.estimated_height_mm) rows.push(['Height', `${(g.estimated_height_mm / 1000).toFixed(2)} m`]);
        if (g.estimated_weight_kg) rows.push(['Weight', `${g.estimated_weight_kg.toLocaleString()} kg`]);
        if (g.primary_materials?.length) rows.push(['Materials', g.primary_materials.join(' · ')]);
        if (rows.length === 0) {
          target.innerHTML = '<p class="empty-line">No geometry data returned.</p>';
          return;
        }
        rows.forEach(([k, v]) => {
          const row = document.createElement('div');
          row.className = 'geo-row';
          row.innerHTML = `<span class="geo-k">${escape(k)}</span><span class="geo-v">${escape(v)}</span>`;
          target.appendChild(row);
        });
      }

      // ---- Helpers ----
      function escape(s: string): string {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }
      function initials(s: string): string {
        return s.split(/\s+/).map((w) => w[0]?.toUpperCase() ?? '').join('').slice(0, 3) || '·';
      }
      function slugify(s: string): string {
        return s.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      }
      function extractSlug(url: string): string {
        const m = url.match(/item\/([^/]+)\/?/);
        return m ? m[1] : '';
      }
      // Map bomwiki categories onto common search terms that have lots of
      // Commons images, so the fallback image search has a chance even when
      // the part name is something obscure like "Pivot Bushing".
      function categoryForCommons(it: any): string {
        const cat = (it.category || '').toLowerCase();
        const sub = (it.sub_assembly || '').toLowerCase();
        if (cat.includes('hydraulic') || sub.includes('hydraulic')) return 'hydraulic cylinder';
        if (cat.includes('engine')) return 'engine';
        if (cat.includes('electrical') || sub.includes('electrical')) return 'electrical wiring';
        if (cat.includes('fastener')) return 'bolt';
        if (cat.includes('wear')) return 'mechanical wear';
        if (cat.includes('control') || sub.includes('control')) return 'control panel';
        if (cat.includes('pneumatic')) return 'pneumatic cylinder';
        if (cat.includes('fluid')) return 'pump';
        if (sub.includes('undercarriage') || cat.includes('structural')) return 'tracked vehicle';
        if (sub.includes('cab') || sub.includes('operator')) return 'operator cab';
        if (sub.includes('blade') || sub.includes('front')) return 'dozer blade';
        if (sub.includes('cooling')) return 'cooling system';
        return '';
      }
      const imageCache = new Map<string, string | null>();

      // Curated fallback for the product hero. bomwiki has product thumbnails
      // for a small set of top-level products. If the LLM-identified product
      // slug (e.g. "cnc-milling-machine") doesn't have a thumb, we try a
      // curated alternative ("cnc-lathe") that does.
      const PRODUCT_IMAGE_FALLBACKS: Record<string, string> = {
        'cnc-machine': 'cnc-lathe',
        'cnc-milling-machine': 'cnc-lathe',
        'cnc-router': 'cnc-lathe',
        'car-engine': 'engine',
        'factory-robots': 'industrial-robot',
        'robot-welding': 'arc-welding-robot',
        '3d-printer': 'fdm-printer',
        'surgical-robot': 'surgical-robot',
        'mri-scanner': 'mri-scanner',
        'dishwasher': 'dishwasher',
        'excavator': 'excavator',
        'bulldozer': 'bulldozer',
      };
      // Direct browser-side probe. Tries the bomwiki thumb URL pattern
      // ({slug}.jpg) by setting it on an <img>; if it loads, we use it,
      // if it errors, we keep the fallback. No server round-trip, so
      // Cloudflare bot-blocking on the server is irrelevant.
      function tryBomwikiThumb(slug: string): Promise<string | null> {
        if (!slug) return Promise.resolve(null);
        const cacheKey = `bw:${slug}`;
        if (imageCache.has(cacheKey)) return Promise.resolve(imageCache.get(cacheKey)!);
        return new Promise((resolve) => {
          const probe = new Image();
          let settled = false;
          const done = (val: string | null) => {
            if (settled) return;
            settled = true;
            imageCache.set(cacheKey, val);
            resolve(val);
          };
          probe.onload = () => done(`https://bomwiki.com/img/thumb/${slug}.jpg`);
          probe.onerror = () => done(null);
          // 4s safety net — if bomwiki is slow, fall back rather than block UI
          setTimeout(() => done(null), 4000);
          probe.src = `https://bomwiki.com/img/thumb/${slug}.jpg`;
        });
      }

      // Search Wikimedia Commons for a real photo matching the given term.
      // Tries the bare query first, then a "mechanical" suffix to bias toward
      // engineering photos when the bare query hits something unrelated
      // (e.g. "Bed" alone returns bedrooms). Returns a 320px-wide thumbnail
      // URL, or null if nothing found. CORS-friendly, no key required.
      async function tryCommonsImage(query: string): Promise<string | null> {
        if (!query || query.length < 3) return null;
        const cacheKey = `cm:${query.toLowerCase()}`;
        if (imageCache.has(cacheKey)) return Promise.resolve(imageCache.get(cacheKey)!);
        try {
          // 1) Search file pages matching the query
          const searchUrl =
            `https://commons.wikimedia.org/w/api.php?action=query&list=search` +
            `&srsearch=${encodeURIComponent(query)}&srnamespace=6&srlimit=1&format=json`;
          const searchRes = await fetch(searchUrl, {
            headers: { 'Api-User-Agent': 'BillOfVision/1.0 (hackathon demo; contact: anonymous)' },
          });
          if (!searchRes.ok) { imageCache.set(cacheKey, null); return null; }
          const searchData = await searchRes.json();
          const hit = searchData?.query?.search?.[0];
          if (!hit) { imageCache.set(cacheKey, null); return null; }
          const title = hit.title as string;

          // 2) Resolve to a 320px thumbnail URL via imageinfo
          const infoUrl =
            `https://commons.wikimedia.org/w/api.php?action=query&titles=${encodeURIComponent(title)}` +
            `&prop=imageinfo&iiprop=url&iiurlwidth=320&format=json`;
          const infoRes = await fetch(infoUrl, {
            headers: { 'Api-User-Agent': 'BillOfVision/1.0 (hackathon demo; contact: anonymous)' },
          });
          if (!infoRes.ok) { imageCache.set(cacheKey, null); return null; }
          const infoData = await infoRes.json();
          const pages = infoData?.query?.pages ?? {};
          const page = Object.values(pages)[0] as any;
          const thumb = page?.imageinfo?.[0]?.thumburl;
          imageCache.set(cacheKey, thumb ?? null);
          return thumb ?? null;
        } catch {
          imageCache.set(cacheKey, null);
          return null;
        }
      }

      // Verify a URL is actually a loadable image (not just a 200 HTML error
      // page that snuck through). Uses an <img> probe so CORS-OK.
      function verifyImage(url: string): Promise<boolean> {
        return new Promise((resolve) => {
          const probe = new Image();
          let settled = false;
          const done = (ok: boolean) => {
            if (settled) return;
            settled = true;
            resolve(ok);
          };
          probe.onload = () => done(true);
          probe.onerror = () => done(false);
          setTimeout(() => done(false), 4000);
          probe.src = url;
        });
      }

      // Unified image finder. Tries multiple sources in order, returns the
      // first one that actually loads as an image.
      // 1. bomwiki thumb (direct URL, no API call)
      // 2. bomwiki curated alternative slug
      // 3. Wikimedia Commons search by part/product name
      // 4. Wikimedia Commons search by part's category (engine, blade, etc.)
      async function findImage(opts: {
        primarySlug?: string;
        altSlug?: string | null;
        nameForSearch: string;
        categoryForSearch?: string;
      }): Promise<string | null> {
        // 1) bomwiki primary
        if (opts.primarySlug) {
          const u = await tryBomwikiThumb(opts.primarySlug);
          if (u) return u;
        }
        // 2) bomwiki alt
        if (opts.altSlug && opts.altSlug !== opts.primarySlug) {
          const u = await tryBomwikiThumb(opts.altSlug);
          if (u) return u;
        }
        // 3) Commons by name. The bare query is usually the best match — adding
        // "mechanical" tends to return old engineering PDFs from Internet Archive.
        const nameQuery = opts.nameForSearch.trim();
        if (nameQuery) {
          const u = await tryCommonsImage(nameQuery);
          if (u) {
            const ok = await verifyImage(u);
            if (ok) return u;
          }
        }
        // 4) Commons by category term
        if (opts.categoryForSearch) {
          const u = await tryCommonsImage(opts.categoryForSearch);
          if (u) {
            const ok = await verifyImage(u);
            if (ok) return u;
          }
        }
        return null;
      }

      // Render the product hero image with a 3-step image chain:
      //   1. bomwiki thumb for the LLM-identified slug
      //   2. bomwiki thumb for a curated alternative slug
      //   3. Wikimedia Commons search by product name
      // If none of those yield a real image, the typographic card stays.
      function renderProductImage(container: HTMLElement, productName: string, productSlug: string) {
        container.innerHTML = '';
        const fallback = document.createElement('div');
        fallback.className = 'hero-art-fallback';
        fallback.innerHTML = `<span class="kicker">Product</span><span class="hero-art-name">${escape(productName)}</span>`;
        container.appendChild(fallback);

        const altSlug = PRODUCT_IMAGE_FALLBACKS[productSlug] && PRODUCT_IMAGE_FALLBACKS[productSlug] !== productSlug
          ? PRODUCT_IMAGE_FALLBACKS[productSlug]
          : null;

        findImage({
          primarySlug: productSlug,
          altSlug,
          nameForSearch: productName,
          categoryForSearch: 'industrial machine',
        }).then((url) => {
          if (!url) return;
          container.innerHTML = '';
          const img = document.createElement('img');
          img.src = url;
          img.alt = productName;
          img.loading = 'lazy';
          img.decoding = 'async';
          container.appendChild(img);
          const cap = document.createElement('span');
          cap.className = 'hero-art-cap';
          // Credit Commons for fallback images, bomwiki for bomwiki-sourced ones
          const isBomwiki = url.includes('bomwiki.com');
          const creditLink = isBomwiki
            ? `<a href="https://bomwiki.com/item/${escape(productSlug)}/" target="_blank" rel="noreferrer">bomwiki.com &rarr;</a>`
            : `<a href="${escape(url)}" target="_blank" rel="noreferrer">Wikimedia Commons &rarr;</a>`;
          cap.innerHTML = creditLink;
          container.appendChild(cap);
        });
      }

      // Capture a frame from the preview video at a given timestamp, return dataURL
      async function captureFrame(t: number, w = 240): Promise<string> {
        return new Promise((resolve, reject) => {
          const v = videoPreview;
          const onSeeked = () => {
            v.removeEventListener('seeked', onSeeked);
            try {
              const canvas = document.createElement('canvas');
              const aspect = (v.videoHeight || 9) / (v.videoWidth || 16);
              canvas.width = w;
              canvas.height = Math.round(w * aspect);
              const ctx = canvas.getContext('2d');
              if (!ctx) return reject(new Error('no ctx'));
              ctx.drawImage(v, 0, 0, canvas.width, canvas.height);
              resolve(canvas.toDataURL('image/jpeg', 0.7));
            } catch (e) {
              reject(e);
            }
          };
          v.addEventListener('seeked', onSeeked, { once: true });
          // Pausing first is more reliable for seek
          v.pause();
          v.currentTime = t;
        });
      }

      // Track which frame tile is currently "active" (the one the user last
      // clicked). The active tile stays highlighted until another tile is
      // clicked, so the user doesn't lose track of which frame they navigated
      // from after the page scrolls.
      let activeFrameIndex: string | null = null;

      function setActiveFrame(idx: string | null) {
        activeFrameIndex = idx;

        // Clear is-selected from every tile, then mark the active one
        document.querySelectorAll<HTMLElement>('#frames-strip .frame-tile').forEach((t) => {
          t.classList.toggle('is-selected', t.dataset.index === idx);
        });

        // Update the sticky bar inside the BOM card
        const bar = $('active-frame-bar') as HTMLElement;
        if (idx === null) {
          bar.hidden = true;
          return;
        }
        const tile = document.querySelector<HTMLElement>(`#frames-strip .frame-tile[data-index="${idx}"]`);
        const tsEl = tile?.querySelector<HTMLElement>('[data-ts]');
        const ts = tsEl?.textContent ?? '—';
        const matches = document.querySelectorAll<HTMLElement>(`.bom-row[data-frame-index="${idx}"]`);

        bar.hidden = false;
        $('active-frame-id').textContent = `frame ${String(Number(idx) + 1).padStart(2, '0')}`;
        $('active-frame-ts').textContent = ts;
        const count = matches.length;
        $('active-frame-count').textContent = `${count} part${count === 1 ? '' : 's'}`;
      }

      // Wire up the frame strip: clicking a frame tile marks it as the
      // active frame (sticky highlight), scrolls down to the part rows
      // that came from that frame, and briefly highlights them.
      function wireFrameStrip() {
        document.querySelectorAll<HTMLElement>('#frames-strip .frame-tile').forEach((tile) => {
          if (tile.dataset.wired === '1') return;
          tile.dataset.wired = '1';
          tile.addEventListener('click', () => {
            const idx = tile.dataset.index;
            if (idx === undefined) return;
            const matches = Array.from(
              document.querySelectorAll<HTMLElement>(`.bom-row[data-frame-index="${idx}"]`)
            );
            if (matches.length === 0) {
              // No parts in this frame — flash the tile and a small hint
              tile.classList.add('is-empty');
              setTimeout(() => tile.classList.remove('is-empty'), 800);
              return;
            }

            // Mark this frame as active (sticky until next click)
            setActiveFrame(idx);

            // Brief pulse on the tile so the user sees the click registered
            tile.classList.add('is-pulsing');
            setTimeout(() => tile.classList.remove('is-pulsing'), 600);

            // Scroll to the first matching row and highlight all of them
            matches[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
            matches.forEach((row, i) => {
              setTimeout(() => {
                row.classList.add('is-highlighted');
                setTimeout(() => row.classList.remove('is-highlighted'), 1800);
              }, i * 80);
            });
          });
        });

        // "clear" button on the sticky bar deselects the active frame
        const clearBtn = $('active-frame-clear');
        if (clearBtn && !clearBtn.dataset.wired) {
          clearBtn.dataset.wired = '1';
          clearBtn.addEventListener('click', () => setActiveFrame(null));
        }
      }

      async function renderFrameStrip() {
        if (!extractionTimestamps.length) return;
        const tiles = document.querySelectorAll<HTMLElement>('#frames-strip .frame-tile');
        const tsEls = document.querySelectorAll<HTMLElement>('#frames-strip [data-ts]');
        // Make sure video is paused and ready
        videoPreview.pause();
        await new Promise<void>((res) => {
          if (videoPreview.readyState >= 2) return res();
          videoPreview.addEventListener('loadeddata', () => res(), { once: true });
        });
        for (let i = 0; i < tiles.length && i < extractionTimestamps.length; i++) {
          tsEls[i].textContent = `${extractionTimestamps[i].toFixed(1)}s`;
          try {
            const url = await captureFrame(extractionTimestamps[i], 320);
            const slot = tiles[i].querySelector('[data-thumb]') as HTMLElement;
            slot.innerHTML = `<img src="${url}" alt="Frame ${i + 1}" /><span class="frame-tile-num">${String(i + 1).padStart(2, '0')}</span>`;
          } catch {
            // leave the placeholder number
          }
        }
      }
    </script>

